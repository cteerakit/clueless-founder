---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonicalPath = `/blog/${post.id}/`;
---

<BaseLayout showDefaultSeo={false}>
  <SEO
    slot="head"
    title={`${post.data.title} — Clueless Founder`}
    description={post.data.description}
    canonicalPath={canonicalPath}
    pubDate={post.data.pubDate}
    jsonLd="BlogPosting"
    post={post}
  />

  <article
    class="prose prose-zinc max-w-none
      prose-headings:font-serif prose-headings:text-zinc-900
      prose-p:text-zinc-700 prose-p:text-[18px] prose-p:leading-relaxed prose-p:font-sans
      prose-blockquote:border-l-2 prose-blockquote:border-black prose-blockquote:not-italic
      prose-blockquote:font-serif prose-blockquote:italic prose-blockquote:quotes-none
      prose-img:w-full prose-img:rounded-sm
      prose-figcaption:text-sm prose-figcaption:font-sans prose-figcaption:text-zinc-400"
  >
    <header class="not-prose mb-12">
      <p class="font-sans text-xs uppercase tracking-wider text-zinc-400">{post.data.category}</p>
      <h1 class="mt-3 font-serif text-4xl italic text-zinc-900">{post.data.title}</h1>
      <time
        class="mt-4 block font-sans text-sm tabular-nums text-zinc-400"
        datetime={post.data.pubDate.toISOString()}
      >
        {
          post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })
        }
      </time>
    </header>

    <Content />
  </article>
</BaseLayout>
