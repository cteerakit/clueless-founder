---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import BlogListItem from '../../components/BlogListItem.astro';
import { estimateReadTime } from '../../utils/reading';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const continueReadingPosts = posts.filter((entry) => entry.id !== post.id).slice(0, 3);

const canonicalPath = `/blog/${post.id}/`;
const readTime = estimateReadTime(post.body ?? '');
const excerpt = post.data.excerpt ?? post.data.description;
const coverImage = post.data.coverImage;
const coverMedium = coverImage?.replace('.webp', '-w896.webp');
const coverLarge = coverImage?.replace('.webp', '-w1120.webp');
---

<BaseLayout showDefaultSeo={false}>
  {coverImage && (
    <Fragment slot="head">
      <link rel="preload" as="image" href={coverMedium} fetchpriority="high" />
    </Fragment>
  )}
  <SEO
    slot="head"
    title={`${post.data.title} — Clueless Founder`}
    description={post.data.description}
    canonicalPath={canonicalPath}
    image={post.data.coverImage}
    pubDate={post.data.pubDate}
    jsonLd="BlogPosting"
    post={post}
  />

  <article
    class="prose prose-base md:prose-lg prose-neutral max-w-none dark:prose-invert
      prose-headings:text-neutral-900 dark:prose-headings:text-neutral-100
      prose-h2:mt-12 prose-h2:mb-4 prose-h2:text-2xl prose-h2:font-normal prose-h2:leading-tight md:prose-h2:text-4xl
      prose-h3:mt-10 prose-h3:text-xl prose-h3:font-normal prose-h3:leading-tight md:prose-h3:text-3xl
      prose-h4:mt-8 prose-h4:text-lg prose-h4:font-normal prose-h4:leading-snug md:prose-h4:text-2xl
      prose-p:text-base prose-p:font-normal prose-p:leading-8 prose-p:text-neutral-700 md:prose-p:text-lg dark:prose-p:text-neutral-300
      prose-li:text-base prose-li:font-normal prose-li:leading-8 prose-li:text-neutral-700 md:prose-li:text-lg dark:prose-li:text-neutral-300
      prose-strong:font-semibold prose-strong:text-[var(--text)]
      prose-a:font-normal prose-a:text-blue-600 dark:prose-a:text-blue-400
      prose-code:text-[0.95em] prose-code:font-medium
      prose-pre:text-[0.95em]
      prose-blockquote:border-l-2 prose-blockquote:border-black dark:prose-blockquote:border-neutral-200
      prose-blockquote:text-[1.08em] prose-blockquote:italic prose-blockquote:quotes-none
      prose-img:w-full prose-img:rounded-[var(--radius-ui)]
      prose-figcaption:text-sm prose-figcaption:text-neutral-400 dark:prose-figcaption:text-neutral-500"
  >
    <header class="not-prose mb-12">
      <p class="text-xs uppercase tracking-wider text-[var(--muted)]">{post.data.category}</p>
      <h1 class="mt-3 text-3xl font-normal leading-tight text-[var(--text)] md:text-5xl">{post.data.title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-[var(--muted)] md:text-lg">{excerpt}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-1 gap-y-1 font-sans text-sm text-[var(--muted)]">
        <span>{post.data.author}</span>
        <span aria-hidden="true">•</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
        </time>
        <span aria-hidden="true">•</span>
        <span>{readTime} min read</span>
      </div>
      {
        coverImage && (
          <img
            src={coverMedium}
            srcset={`${coverMedium} 896w, ${coverLarge} 1120w`}
            sizes="(min-width: 768px) 768px, 100vw"
            alt={post.data.title}
            class="mt-8 w-full rounded-[var(--radius-ui)] object-cover"
            loading="eager"
            fetchpriority="high"
            width="896"
            height="504"
          />
        )
      }
    </header>

    <Content />
  </article>
  <script is:inline>
    const applyIntrinsicSize = () => {
      const images = document.querySelectorAll('article.prose img:not([width]):not([height])');
      images.forEach((image) => {
        const setSize = () => {
          if (!image.naturalWidth || !image.naturalHeight) return;
          image.setAttribute('width', String(image.naturalWidth));
          image.setAttribute('height', String(image.naturalHeight));
        };
        if (image.complete) {
          setSize();
        } else {
          image.addEventListener('load', setSize, { once: true });
        }
      });
    };
    applyIntrinsicSize();
    document.addEventListener('astro:page-load', applyIntrinsicSize);
  </script>

  <section class="not-prose mt-8">
    <div class="rounded-[var(--radius-ui)] border border-[var(--line)] bg-[var(--hover)] p-8">
      <p class="text-xs uppercase tracking-wider text-[var(--muted)]">Keep in touch</p>
      <h2 class="mt-3 text-3xl text-[var(--text)]">Get practical founder notes weekly.</h2>
      <p class="mt-3 max-w-2xl text-base text-[var(--muted)]">
        Real lessons from shipping products, pricing experiments, and honest postmortems.
      </p>
      <button
        type="button"
        data-newsletter-open
        class="mt-6 inline-flex items-center rounded-[var(--radius-ui)] bg-[var(--text)] px-6 py-3 text-xs font-medium uppercase tracking-[0.2em] text-[var(--bg)] transition-opacity hover:opacity-90"
      >
        Join the newsletter
      </button>
    </div>
  </section>

  {
    continueReadingPosts.length > 0 && (
      <section class="not-prose mt-8">
        <p class="text-xs uppercase tracking-wider text-[var(--muted)]">Continue reading</p>
        <ul class="mt-4 divide-y divide-[var(--line)]">
          {continueReadingPosts.map((entry) => <BlogListItem post={entry} />)}
        </ul>
      </section>
    )
  }
</BaseLayout>
