---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogListItem from '../../components/BlogListItem.astro';
import { SITE_TITLE } from '../../consts';
import { slugifySegment } from '../../utils/slugify';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const topics = Array.from(new Set(posts.map((post) => post.data.category.trim())));

  return topics.map((topic) => ({
    params: { topic: slugifySegment(topic) },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((post) => slugifySegment(post.data.category) === slugifySegment(topic))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={`${topic} — Topics — ${SITE_TITLE}`}
  description={`Browse all ${topic} posts from Clueless Founder.`}
  canonicalPath={`/topics/${slugifySegment(topic)}/`}
>
  <section class="border-b border-[var(--line)] pb-10">
    <p class="font-sans text-xs uppercase tracking-wider text-[var(--muted)]">Topic</p>
    <h1 class="mt-3 font-serif text-4xl text-[var(--text)] md:text-5xl">{topic}</h1>
    <p class="mt-4 max-w-2xl text-base text-[var(--muted)] md:text-lg">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'} in this topic.
    </p>
  </section>

  <ul class="mt-8 divide-y divide-[var(--line)]">
    {posts.map((post) => <BlogListItem post={post} />)}
  </ul>
</BaseLayout>

