---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { slugifySegment } from '../../utils/slugify';

export const prerender = true;

const posts = await getCollection('blog', ({ data }) => !data.draft);
const topicCount = new Map<string, number>();

for (const post of posts) {
  const topic = post.data.category.trim();
  topicCount.set(topic, (topicCount.get(topic) ?? 0) + 1);
}

const topics = Array.from(topicCount.entries())
  .map(([name, count]) => ({ name, count, slug: slugifySegment(name) }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));
---

<BaseLayout
  title={`Topics — ${SITE_TITLE}`}
  description="Browse all writing topics from Clueless Founder."
  canonicalPath="/topics/"
>
  <section class="border-b border-[var(--line)] pb-10">
    <h1 class="font-serif text-4xl text-[var(--text)] md:text-5xl">Topics</h1>
    <p class="mt-4 max-w-2xl text-base text-[var(--muted)] md:text-lg">
      Browse posts by topic.
    </p>
  </section>

  <ul class="mt-8 divide-y divide-[var(--line)]">
    {
      topics.map((topic) => (
        <li>
          <a
            href={`/topics/${topic.slug}/`}
            class="-mx-4 flex items-center justify-between px-4 py-4 transition-colors hover:bg-[var(--hover)]"
          >
            <span class="text-lg text-[var(--text)]">{topic.name}</span>
            <span class="font-sans text-sm text-[var(--muted)]">
              {topic.count} {topic.count === 1 ? 'post' : 'posts'}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

