---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BlogListItem from '../components/BlogListItem.astro';

export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const INITIAL_POSTS = 6;
const lcpImageSrc = posts[0]?.data.coverImage;

---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} canonicalPath="/">
  {lcpImageSrc && (
    <Fragment slot="head">
      <link rel="preload" as="image" href={lcpImageSrc} fetchpriority="high" />
    </Fragment>
  )}
  <section class="border-b border-[var(--line)] pb-16 text-center">
    <h1 class="font-serif text-6xl leading-tight text-[var(--text)]">{SITE_TITLE}</h1>
    <p class="mx-auto mt-6 max-w-xl text-lg text-[var(--muted)]">{SITE_DESCRIPTION}</p>
  </section>

  <ul class="divide-y divide-[var(--line)]">
    {
      posts.map((post, index) => (
        <BlogListItem
          post={post}
          prioritizeImage={index === 0}
          deferLoad={index >= INITIAL_POSTS}
        />
      ))
    }
  </ul>
  <div id="feed-sentinel" class="py-6 text-center text-sm text-[var(--muted)]">Loading more posts...</div>
  <noscript>
    <style>
      [data-infinite-item='true'] { display: list-item !important; }
      #feed-sentinel { display: none; }
    </style>
  </noscript>
  <script>
    const hiddenItems = Array.from(document.querySelectorAll("[data-infinite-item='true']"));
    const sentinel = document.getElementById('feed-sentinel');
    const BATCH_SIZE = 4;
    let index = 0;

    const revealNextBatch = () => {
      const batch = hiddenItems.slice(index, index + BATCH_SIZE);
      batch.forEach((item) => {
        item.style.display = 'list-item';
        item.removeAttribute('aria-hidden');
        item.removeAttribute('data-infinite-item');
      });
      index += batch.length;
      if (index >= hiddenItems.length && sentinel) {
        sentinel.remove();
      }
    };

    if (!hiddenItems.length) {
      sentinel?.remove();
    } else if (!('IntersectionObserver' in window)) {
      revealNextBatch();
      while (index < hiddenItems.length) {
        revealNextBatch();
      }
    } else if (sentinel) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) {
            return;
          }
          revealNextBatch();
          if (index >= hiddenItems.length) {
            observer.disconnect();
          }
        },
        { rootMargin: '200px 0px' },
      );
      observer.observe(sentinel);
    }
  </script>
</BaseLayout>
