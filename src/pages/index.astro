---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BlogListItem from '../components/BlogListItem.astro';

export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const INITIAL_POSTS = 10;

---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} canonicalPath="/">
  <section class="border-b border-[var(--line)] pb-16 text-center">
    <h1 class="font-serif text-4xl leading-tight text-[var(--text)] md:text-6xl">{SITE_TITLE}</h1>
    <p class="mx-auto mt-6 max-w-lg text-base text-[var(--muted)] md:max-w-xl md:text-lg">{SITE_DESCRIPTION}</p>
  </section>

  <ul id="post-feed" class="divide-y divide-[var(--line)]">
    {
      posts.map((post, index) => (
        <BlogListItem
          post={post}
          prioritizeImage={index === 0}
          deferLoad={index >= INITIAL_POSTS}
        />
      ))
    }
  </ul>
  <div id="feed-controls" class="py-6 text-center">
    <button
      id="load-more-posts"
      type="button"
      aria-controls="post-feed"
      aria-describedby="feed-status"
      class="font-sans rounded-[var(--radius-ui)] border border-[var(--line)] px-4 py-2 text-sm font-medium text-[var(--text)] transition-colors hover:bg-[var(--hover)]"
    >
      Load more posts
    </button>
    <p id="feed-status" class="sr-only" aria-live="polite"></p>
  </div>
  <noscript>
    <style>
      [data-infinite-item='true'] { display: list-item !important; }
      #load-more-posts { display: none; }
    </style>
  </noscript>
  <script>
    const setupLoadMorePosts = () => {
      const hiddenItems = Array.from(document.querySelectorAll("[data-infinite-item='true']"));
      const loadMoreButton = document.getElementById('load-more-posts');
      const feedStatus = document.getElementById('feed-status');
      const BATCH_SIZE = 5;
      let index = 0;
      const totalHidden = hiddenItems.length;

      const updateStatus = (message) => {
        if (!feedStatus) return;
        feedStatus.textContent = message;
      };

      const updateButtonLabel = () => {
        if (!loadMoreButton) return;
        const remaining = Math.max(totalHidden - index, 0);
        if (remaining > 0) {
          loadMoreButton.textContent = `Load more posts (${remaining} remaining)`;
        } else {
          loadMoreButton.textContent = 'No more posts';
        }
      };

      const revealNextBatch = () => {
        const batch = hiddenItems.slice(index, index + BATCH_SIZE);
        batch.forEach((item) => {
          item.style.display = 'list-item';
          item.removeAttribute('aria-hidden');
          item.removeAttribute('data-infinite-item');
        });
        index += batch.length;
        const remaining = Math.max(totalHidden - index, 0);
        updateStatus(
          remaining > 0
            ? `Loaded ${batch.length} more posts. ${remaining} posts remaining.`
            : `Loaded ${batch.length} more posts. You reached the end of the feed.`
        );
        updateButtonLabel();
        if (index >= hiddenItems.length && loadMoreButton) {
          const controls = document.getElementById('feed-controls');
          if (controls) {
            controls.innerHTML =
              '<p class="font-sans text-sm text-[var(--muted)]">You made it to the end. Time to build something weird.</p>';
          } else {
            loadMoreButton.remove();
          }
        }
      };

      if (!hiddenItems.length) {
        updateStatus('All posts are already visible.');
        loadMoreButton?.remove();
      } else if (loadMoreButton) {
        updateButtonLabel();
        updateStatus(`${totalHidden} posts are hidden. Use the button to load more posts.`);
        loadMoreButton.addEventListener('click', revealNextBatch, { once: false });
      }
    };

    setupLoadMorePosts();
    if (!window.__loadMorePostsSetupBound) {
      window.__loadMorePostsSetupBound = true;
      document.addEventListener('astro:page-load', setupLoadMorePosts);
    }
  </script>
</BaseLayout>
