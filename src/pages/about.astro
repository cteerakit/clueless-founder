---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

export const prerender = true;

const title = `About — ${SITE_TITLE}`;
---

<BaseLayout title={title} description={SITE_DESCRIPTION} canonicalPath="/about/">
  <article class="prose prose-zinc dark:prose-invert max-w-none prose-headings:font-serif prose-p:text-[18px] prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300">
    <h1 class="font-serif text-4xl italic text-[var(--text)]">About</h1>
    <p class="font-sans text-zinc-700 dark:text-zinc-300">{SITE_DESCRIPTION}</p>
    <p class="font-sans text-zinc-700 dark:text-zinc-300">
      Built with{' '}
      <a href="https://astro.build" class="text-[var(--text)] underline decoration-zinc-300 dark:decoration-zinc-700 underline-offset-4">
        Astro
      </a>{' '}
      and deployed on Cloudflare.
    </p>
  </article>
</BaseLayout>
