---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/Newsletter.astro';
import { SITE_TITLE } from '../consts';

export const prerender = true;

const title = `Newsletter — ${SITE_TITLE}`;
const description =
  'Subscribe for occasional emails when there is something worth sending.';
---

<BaseLayout title={title} description={description} canonicalPath="/newsletter/">
  <NewsletterSignup />
</BaseLayout>
