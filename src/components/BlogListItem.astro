---
import type { CollectionEntry } from 'astro:content';
import { estimateReadTime } from '../utils/reading';
import { ArrowUpRight } from '@lucide/astro';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const excerpt = post.data.excerpt ?? post.data.description;
---

<li>
  <a
    href={`/blog/${post.id}/`}
    class="-mx-4 flex flex-col justify-between gap-4 px-4 py-4 transition-colors hover:bg-[var(--hover)] md:flex-row"
  >
    <span class="min-w-0 flex-1">
      <span class="block font-serif text-xl font-normal text-[var(--text)]">{post.data.title}</span>
      <span class="mt-2 block max-w-2xl font-sans text-sm leading-relaxed text-[var(--muted)]">{excerpt}</span>
    </span>
    <span class="flex shrink-0 items-center gap-4 md:items-start">
      <span class="text-right md:pt-1">
        <time class="block font-sans text-sm tabular-nums text-[var(--muted)]" datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
        <span class="mt-1 block font-sans text-xs text-[var(--muted)]">{estimateReadTime(post.body ?? '')} min read</span>
      </span>
      <span class="text-[var(--muted)]" aria-hidden="true">
        <ArrowUpRight size={20} stroke-width={1.5} />
      </span>
    </span>
    {
      post.data.coverImage && (
        <img
          src={post.data.coverImage}
          alt={post.data.title}
          class="order-first aspect-video w-full rounded-[var(--radius-ui)] object-cover md:order-none md:w-56"
          loading="lazy"
        />
      )
    }
  </a>
</li>
