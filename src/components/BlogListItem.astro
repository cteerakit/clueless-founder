---
import type { CollectionEntry } from 'astro:content';
import { estimateReadTime } from '../utils/reading';
import { ArrowUpRight } from '@lucide/astro';

type Props = {
  post: CollectionEntry<'blog'>;
  prioritizeImage?: boolean;
};

const { post, prioritizeImage = false } = Astro.props;
const excerpt = post.data.excerpt ?? post.data.description;
---

<li>
  <a
    href={`/blog/${post.id}/`}
    class="-mx-4 flex flex-col justify-between gap-4 px-4 py-4 transition-colors hover:bg-[var(--hover)] md:flex-row"
  >
    <span class="min-w-0 flex-1">
      <span class="block text-xl font-medium text-[var(--text)]">{post.data.title}</span>
      <span class="mt-2 block max-w-2xl text-sm leading-relaxed text-[var(--muted)]">{excerpt}</span>
    </span>
    <span
      class="flex w-full shrink-0 items-start justify-between gap-3 md:w-auto md:items-center md:justify-start md:gap-4"
    >
      <span
        class="flex flex-wrap items-center justify-start gap-x-1 text-left font-sans text-sm text-[var(--muted)] md:justify-end md:pt-1"
      >
        <time class="tabular-nums" datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </time>
        <span aria-hidden="true">•</span>
        <span>{estimateReadTime(post.body ?? '')} min read</span>
      </span>
      <span class="text-[var(--muted)]" aria-hidden="true">
        <ArrowUpRight size={20} stroke-width={1.5} />
      </span>
    </span>
    {
      post.data.coverImage && (
        <img
          src={post.data.coverImage}
          alt={post.data.title}
          class="order-first aspect-video w-full rounded-[var(--radius-ui)] object-cover md:order-none md:w-56"
          loading={prioritizeImage ? 'eager' : 'lazy'}
          fetchpriority={prioritizeImage ? 'high' : 'auto'}
        />
      )
    }
  </a>
</li>
