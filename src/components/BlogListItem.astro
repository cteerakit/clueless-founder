---
import type { CollectionEntry } from 'astro:content';
import { estimateReadTime } from '../utils/reading';

type Props = {
  post: CollectionEntry<'blog'>;
  prioritizeImage?: boolean;
  deferLoad?: boolean;
};

const { post, prioritizeImage = false, deferLoad = false } = Astro.props;
const excerpt = post.data.excerpt ?? post.data.description;
const coverImage = post.data.coverImage;
const coverSmall = coverImage?.replace('.webp', '-w448.webp');
const coverMedium = coverImage?.replace('.webp', '-w672.webp');
const coverLarge = coverImage?.replace('.webp', '-w896.webp');
---

<li
  data-infinite-item={deferLoad ? 'true' : undefined}
  aria-hidden={deferLoad ? 'true' : undefined}
  style={deferLoad ? 'display: none;' : undefined}
>
  <a
    href={`/blog/${post.id}/`}
    class="-mx-4 flex flex-col justify-between gap-4 px-4 py-4 transition-colors hover:bg-[var(--hover)] md:flex-row md:items-center"
  >
    <span class="min-w-0 flex-1">
      <span class="block text-xl font-medium text-[var(--text)]">{post.data.title}</span>
      <span class="mt-2 block max-w-2xl text-sm leading-relaxed text-[var(--muted)]">{excerpt}</span>
      <span
        class="mt-2 flex flex-wrap items-center justify-start gap-x-1 text-left font-sans text-sm text-[var(--muted)]"
      >
        <time class="tabular-nums" datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </time>
        <span aria-hidden="true">•</span>
        <span>{estimateReadTime(post.body ?? '')} min read</span>
      </span>
    </span>
    {
      coverImage && (
        <img
          src={coverMedium}
          srcset={`${coverSmall} 448w, ${coverMedium} 672w, ${coverLarge} 896w`}
          sizes="(min-width: 768px) 224px, 100vw"
          alt={post.data.title}
          class="order-first aspect-video w-full rounded-[var(--radius-ui)] object-cover md:order-none md:w-56"
          loading={prioritizeImage ? 'eager' : 'lazy'}
          fetchpriority={prioritizeImage ? 'high' : 'auto'}
          width="672"
          height="378"
        />
      )
    }
  </a>
</li>
