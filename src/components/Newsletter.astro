---
---

<div
  id="newsletter-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center px-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="newsletter-heading"
>
  <button
    id="newsletter-overlay"
    type="button"
    class="absolute inset-0 bg-black/50 backdrop-blur-[1px]"
    aria-label="Close newsletter modal"
  ></button>
  <section class="relative w-full max-w-lg border border-[var(--line)] bg-[var(--bg)] p-8 shadow-xl">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 id="newsletter-heading" class="font-serif text-2xl italic text-[var(--text)]">Subscribe</h2>
        <p class="mt-2 font-sans text-sm text-[var(--muted)]">
          Occasional notes. No spam - unsubscribe anytime.
        </p>
      </div>
      <button
        id="newsletter-close"
        type="button"
        class="shrink-0 text-sm text-[var(--muted)] transition-colors hover:text-[var(--text)]"
        aria-label="Close newsletter modal"
      >
        Close
      </button>
    </div>

    <form id="newsletter-form" class="mt-8 flex flex-col gap-6 sm:flex-row sm:items-end">
      <label class="block flex-1 font-sans text-sm text-[var(--muted)]">
        <span class="sr-only">Email</span>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class="w-full border-0 border-b border-[var(--line)] bg-transparent py-3 font-sans text-base text-[var(--text)] outline-none placeholder:text-[var(--muted)] focus:border-[var(--text)]"
        />
      </label>
      <button
        type="submit"
        class="shrink-0 bg-[var(--text)] px-8 py-3 font-sans text-xs font-medium uppercase tracking-[0.2em] text-[var(--bg)] transition-opacity hover:opacity-90"
      >
        Subscribe
      </button>
    </form>

    <p id="newsletter-success" class="mt-6 hidden font-sans text-sm text-[var(--muted)]">
      Thanks - you're on the list.
    </p>
    <p id="newsletter-error" class="mt-6 hidden font-sans text-sm text-red-600" role="alert"></p>
  </section>
</div>

<script>
  import { actions, isInputError } from 'astro:actions';

  const modal = document.getElementById('newsletter-modal');
  const overlay = document.getElementById('newsletter-overlay');
  const closeButton = document.getElementById('newsletter-close');
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;
  const successEl = document.getElementById('newsletter-success');
  const errorEl = document.getElementById('newsletter-error');

  const setOpen = (open: boolean) => {
    if (!modal) return;
    modal.classList.toggle('hidden', !open);
    modal.classList.toggle('flex', open);
    document.body.classList.toggle('overflow-hidden', open);
    if (open) emailInput?.focus();
  };

  const openNewsletterModal = () => {
    form?.classList.remove('hidden');
    form?.reset();
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');
    setOpen(true);
  };

  document.querySelectorAll<HTMLElement>('[data-newsletter-open]').forEach((trigger) => {
    trigger.addEventListener('click', (event) => {
      event.preventDefault();
      openNewsletterModal();
    });
  });

  overlay?.addEventListener('click', () => setOpen(false));
  closeButton?.addEventListener('click', () => setOpen(false));

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setOpen(false);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    const fd = new FormData(form);
    const email = fd.get('email');
    const result = await actions.subscribe({
      email: typeof email === 'string' ? email : '',
    });

    if (result.error) {
      let msg = result.error.message;
      if (isInputError(result.error)) {
        msg = result.error.fields.email?.join(', ') ?? msg;
      }
      if (errorEl) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }
      return;
    }

    form?.classList.add('hidden');
    successEl?.classList.remove('hidden');
  });
</script>
