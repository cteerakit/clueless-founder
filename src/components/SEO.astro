---
import type { CollectionEntry } from 'astro:content';

type Props = {
  title: string;
  description: string;
  canonicalPath: string;
  pubDate?: Date;
  modifiedDate?: Date;
  image?: string;
  jsonLd?: 'BlogPosting' | 'WebSite';
  post?: CollectionEntry<'blog'>;
};

const {
  title,
  description,
  canonicalPath,
  pubDate,
  modifiedDate,
  image,
  jsonLd = 'WebSite',
  post,
} = Astro.props;

const site = Astro.site ?? new URL('http://localhost:4321');
const canonical = new URL(canonicalPath.replace(/^\//, ''), site).href;
const ogImageSource = image ?? '/landscape_Cover2.avif';
const ogImage = new URL(ogImageSource.replace(/^\//, ''), site).href;
const siteOrigin = site.origin;
const siteName = 'Clueless Founder';
const logoUrl = new URL('logo-trans.png', site).href;
const authorName = 'Teerakit Chantrakul';
const authorUrl = new URL('about/', site).href;
const authorImage = new URL('teerakit-profile.png', site).href;
const organizationId = `${siteOrigin}/#organization`;
const personId = `${authorUrl}#person`;
const socialProfiles = [
  'https://www.linkedin.com/newsletters/clueless-founder-7161585325901819904/',
  'https://x.com/cteerakit',
  'https://github.com/cteerakit',
  'https://medium.com/@cteerakit',
  'https://substack.com/@cteerakit',
  'https://www.linkedin.com/in/cteerakit/',
  'https://www.instagram.com/cteerakit/',
  'https://www.facebook.com/cteerakit/',
];

const postingLd =
  jsonLd === 'BlogPosting' && post
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: post.data.title,
        description: post.data.description,
        datePublished: post.data.pubDate.toISOString(),
        dateModified: (modifiedDate ?? post.data.pubDate).toISOString(),
        author: {
          '@id': personId,
        },
        publisher: {
          '@id': organizationId,
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonical,
        },
      }
    : null;

const webSiteLd =
  jsonLd === 'WebSite'
    ? {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: siteName,
        url: siteOrigin,
        description,
        inLanguage: 'en',
        publisher: {
          '@id': organizationId,
        },
      }
    : null;

const organizationLd =
  jsonLd === 'WebSite' || jsonLd === 'BlogPosting'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Organization',
        '@id': organizationId,
        name: siteName,
        url: siteOrigin,
        logo: {
          '@type': 'ImageObject',
          url: logoUrl,
        },
        sameAs: socialProfiles,
      }
    : null;

const personLd =
  jsonLd === 'WebSite' || jsonLd === 'BlogPosting'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Person',
        '@id': personId,
        name: authorName,
        url: authorUrl,
        image: {
          '@type': 'ImageObject',
          url: authorImage,
        },
        sameAs: socialProfiles,
      }
    : null;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content={jsonLd === 'BlogPosting' ? 'article' : 'website'} />
<meta property="og:site_name" content="Clueless Founder" />
{ogImage && <meta property="og:image" content={ogImage} />}
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}

{postingLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(postingLd)} />
)}
{webSiteLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(webSiteLd)} />
)}
{organizationLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationLd)} />
)}
{personLd && (
  <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)} />
)}
