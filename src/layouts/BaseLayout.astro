---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import SEO from '../components/SEO.astro';
import NewsletterModal from '../components/Newsletter.astro';
import { Moon, Sun } from '@lucide/astro';
import { Camera, Play, X } from '@lucide/astro';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  /** For pages that define their own head, pass false and include SEO in the slot */
  showDefaultSeo?: boolean;
};

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalPath = '/',
  showDefaultSeo = true,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="font-sans antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo-trans.png" />
    <link rel="shortcut icon" href="/logo-trans.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#18181b" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>

    {
      Astro.site && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={SITE_TITLE}
          href={new URL('rss.xml', Astro.site).href}
        />
      )
    }

    {showDefaultSeo && <SEO title={title} description={description} canonicalPath={canonicalPath} />}
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--text)] transition-colors">
    <div class="mx-auto flex min-h-screen w-full max-w-3xl flex-col px-6 py-12">
      <header class="flex flex-wrap items-center justify-between gap-4 border-b border-[var(--line)] pb-4">
        <a href="/" class="inline-flex items-center hover:opacity-80">
          <img src="/logo-trans.png" alt={SITE_TITLE} class="h-8 w-auto dark:invert" />
        </a>
        <nav class="flex items-center gap-6 font-sans text-sm text-[var(--muted)]">
          <a href="/about/" class="transition-colors hover:text-[var(--text)]">About</a>
          <button
            type="button"
            data-newsletter-open
            class="transition-colors hover:text-[var(--text)]"
            aria-label="Open subscribe modal"
          >
            Subscribe
          </button>
          <button
            id="theme-toggle"
            type="button"
            class="group relative inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-full border border-[var(--line)] transition-colors hover:bg-[var(--hover)]"
            aria-label="Toggle color theme"
          >
            <span class="sr-only">Toggle color theme</span>
            <Sun
              id="theme-sun"
              class="absolute h-4 w-4 text-[var(--text)] transition-all duration-300 ease-out group-hover:scale-110 dark:scale-0 dark:rotate-90 dark:opacity-0"
              aria-hidden="true"
              stroke-width={1.8}
            />
            <Moon
              id="theme-moon"
              class="absolute h-4 w-4 rotate-90 scale-0 text-[var(--text)] opacity-0 transition-all duration-300 ease-out group-hover:scale-110 dark:rotate-0 dark:scale-100 dark:opacity-100"
              aria-hidden="true"
              stroke-width={1.8}
            />
          </button>
        </nav>
      </header>

      <main class="mt-16 flex-1">
        <slot />
      </main>

      <footer class="mt-0 border-t border-[var(--line)] pt-8">
        <div class="flex flex-wrap items-start justify-between gap-8">
          <div>
            <nav class="flex flex-wrap gap-x-4 gap-y-2 font-sans text-sm text-[var(--muted)]">
              <a href="/about/" class="transition-colors hover:text-[var(--text)]">About</a>
              <button
                type="button"
                data-newsletter-open
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Open subscribe modal"
              >
                Subscribe
              </button>
              <a href="/rss.xml" class="transition-colors hover:text-[var(--text)]">RSS</a>
            </nav>
          </div>

          <div>
            <div class="flex flex-wrap items-center gap-4 text-[var(--muted)]">
              <a
                href="https://x.com/"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Twitter/X"
                title="Twitter/X"
              >
                <X size={16} stroke-width={1.8} />
              </a>
              <a
                href="https://instagram.com/"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Instagram"
                title="Instagram"
              >
                <Camera size={16} stroke-width={1.8} />
              </a>
              <a
                href="https://youtube.com/"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="YouTube"
                title="YouTube"
              >
                <Play size={16} stroke-width={1.8} />
              </a>
            </div>
          </div>
        </div>

        <p class="mt-8 font-sans text-xs text-[var(--muted)]">
          © {new Date().getFullYear()} {SITE_TITLE}. All rights reserved.
        </p>
      </footer>
    </div>
    <NewsletterModal />
    <script is:inline>
      const root = document.documentElement;
      const button = document.getElementById('theme-toggle');
      let animating = false;
      const supportsViewTransition = 'startViewTransition' in document;
      const setThemeLabel = () => {
        if (!button) return;
        const isDark = root.classList.contains('dark');
        button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        button.setAttribute('title', isDark ? 'Light mode' : 'Dark mode');
      };
      const animateThemeReveal = async (fromEl, nextDark) => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion || !supportsViewTransition) {
          root.classList.toggle('dark', nextDark);
          return;
        }

        const rect = fromEl.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;
        const maxX = Math.max(x, window.innerWidth - x);
        const maxY = Math.max(y, window.innerHeight - y);
        const radius = Math.hypot(maxX, maxY);

        root.style.setProperty('--reveal-x', `${x}px`);
        root.style.setProperty('--reveal-y', `${y}px`);
        root.style.setProperty('--reveal-radius', `${radius}px`);
        root.classList.add('theme-reveal');

        const transition = document.startViewTransition(() => {
          root.classList.toggle('dark', nextDark);
        });
        await transition.finished.finally(() => {
          root.classList.remove('theme-reveal');
          root.style.removeProperty('--reveal-x');
          root.style.removeProperty('--reveal-y');
          root.style.removeProperty('--reveal-radius');
        });
      };
      setThemeLabel();
      button?.addEventListener('click', async () => {
        if (animating) return;
        animating = true;
        button.setAttribute('disabled', 'true');
        const nextDark = !root.classList.contains('dark');
        await animateThemeReveal(button, nextDark);
        localStorage.setItem('theme', nextDark ? 'dark' : 'light');
        setThemeLabel();
        button.removeAttribute('disabled');
        animating = false;
      });
    </script>
  </body>
</html>
