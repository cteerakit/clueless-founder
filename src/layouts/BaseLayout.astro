---
import '../styles/global.css';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import SEO from '../components/SEO.astro';
import NewsletterModal from '../components/Newsletter.astro';
import { Moon, Sun } from '@lucide/astro';
import { ClientRouter } from 'astro:transitions';
import interLatin400Woff2 from '@fontsource/inter/files/inter-latin-400-normal.woff2?url';
import interLatin500Woff2 from '@fontsource/inter/files/inter-latin-500-normal.woff2?url';
import newsreaderLatinWghtWoff2 from '@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  /** For pages that define their own head, pass false and include SEO in the slot */
  showDefaultSeo?: boolean;
};

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalPath = '/',
  showDefaultSeo = true,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="font-sans antialiased no-page-transition">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo-trans.png" />
    <link rel="shortcut icon" href="/logo-trans.png" />
    <link rel="preload" href={interLatin400Woff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interLatin500Woff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={newsreaderLatinWghtWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#18181b" />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored ? stored === 'dark' : prefersDark;
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>

    {
      Astro.site && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={SITE_TITLE}
          href={new URL('rss.xml', Astro.site).href}
        />
      )
    }

    {showDefaultSeo && <SEO title={title} description={description} canonicalPath={canonicalPath} />}
    <slot name="head" />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--text)] transition-colors">
    <div class="mx-auto flex min-h-screen w-full max-w-3xl flex-col px-6 pt-0 pb-12">
      <div
        id="site-header"
        class="site-header sticky top-0 z-30 -mx-6 bg-[var(--bg)] px-6 pt-4"
      >
        <header class="flex flex-wrap items-center justify-between gap-4 border-b border-[var(--line)] pb-4">
          <a href="/" class="inline-flex items-center hover:opacity-80">
            <img src="/logo-trans.png" alt={SITE_TITLE} class="h-8 w-auto dark:invert" />
          </a>
          <nav class="flex items-center gap-6 font-sans text-sm text-[var(--muted)]">
            <a href="/about/" class="transition-colors hover:text-[var(--text)]">About</a>
            <button
              type="button"
              data-newsletter-open
              class="transition-colors hover:text-[var(--text)]"
              aria-label="Open subscribe modal"
            >
              Subscribe
            </button>
            <button
              id="theme-toggle"
              type="button"
              class="group relative inline-flex h-8 w-8 cursor-pointer items-center justify-center rounded-full border border-[var(--line)] transition-colors hover:bg-[var(--hover)]"
              aria-label="Toggle color theme"
            >
              <span class="sr-only">Toggle color theme</span>
              <Sun
                id="theme-sun"
                class="absolute h-4 w-4 text-[var(--text)] transition-all duration-300 ease-out group-hover:scale-110 dark:scale-0 dark:rotate-90 dark:opacity-0"
                aria-hidden="true"
                stroke-width={1.8}
              />
              <Moon
                id="theme-moon"
                class="absolute h-4 w-4 rotate-90 scale-0 text-[var(--text)] opacity-0 transition-all duration-300 ease-out group-hover:scale-110 dark:rotate-0 dark:scale-100 dark:opacity-100"
                aria-hidden="true"
                stroke-width={1.8}
              />
            </button>
          </nav>
        </header>
      </div>

      <main id="page-content" class="mt-16 flex-1">
        <slot />
      </main>

      <footer class="mt-0 border-t border-[var(--line)] pt-8">
        <div class="flex flex-wrap items-start justify-between gap-8">
          <div>
            <nav class="flex flex-wrap gap-x-4 gap-y-2 font-sans text-sm text-[var(--muted)]">
              <a href="/about/" class="transition-colors hover:text-[var(--text)]">About</a>
              <button
                type="button"
                data-newsletter-open
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Open subscribe modal"
              >
                Subscribe
              </button>
              <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[var(--text)]">RSS</a>
            </nav>
          </div>

          <div>
            <div class="flex flex-wrap items-center gap-4 text-[var(--muted)]">
              <a
                href="https://www.linkedin.com/in/cteerakit/"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="LinkedIn"
                title="LinkedIn"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-[#71717a] dark:fill-[#d4d4d8]">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </a>
              <a
                href="https://medium.com/@cteerakit"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Medium"
                title="Medium"
              >
                <img src="https://cdn.simpleicons.org/medium/71717a/d4d4d8" alt="" class="h-4 w-4" loading="lazy" />
              </a>
              <a
                href="https://clueless-founder.substack.com"
                target="_blank"
                rel="noreferrer"
                class="transition-colors hover:text-[var(--text)]"
                aria-label="Substack"
                title="Substack"
              >
                <img src="https://cdn.simpleicons.org/substack/71717a/d4d4d8" alt="" class="h-4 w-4" loading="lazy" />
              </a>
            </div>
          </div>
        </div>

        <p class="mt-8 font-sans text-xs text-[var(--muted)]">
          © {new Date().getFullYear()} {SITE_TITLE}. All rights reserved.
        </p>
      </footer>
    </div>
    <NewsletterModal />
    <script is:inline>
      const root = document.documentElement;
      const supportsViewTransition = 'startViewTransition' in document;
      const getResolvedDark = () => {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark') return true;
        if (stored === 'light') return false;
        return window.matchMedia('(prefers-color-scheme: dark)').matches;
      };
      const applyTheme = (isDark) => {
        root.classList.toggle('dark', isDark);
      };
      const syncThemeToIncomingDocument = (incomingDocument) => {
        incomingDocument.documentElement.classList.toggle('dark', root.classList.contains('dark'));
        incomingDocument.documentElement.classList.toggle(
          'no-page-transition',
          root.classList.contains('no-page-transition')
        );
      };
      const enablePageTransitionsAfterFirstLoad = () => {
        // Skip first-render transition cost, then keep transitions enabled for all next navigations.
        if (!root.classList.contains('no-page-transition')) return;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            root.classList.remove('no-page-transition');
          });
        });
      };
      const getThemeButton = () => document.getElementById('theme-toggle');
      const setThemeLabel = () => {
        const button = getThemeButton();
        if (!button) return;
        const isDark = root.classList.contains('dark');
        button.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
        button.setAttribute('title', isDark ? 'Light mode' : 'Dark mode');
      };
      const animateThemeReveal = async (fromEl, nextDark) => {
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion || !supportsViewTransition) {
          root.classList.toggle('dark', nextDark);
          return;
        }

        const rect = fromEl.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;
        const maxX = Math.max(x, window.innerWidth - x);
        const maxY = Math.max(y, window.innerHeight - y);
        const radius = Math.hypot(maxX, maxY);

        root.classList.add('theme-reveal');

        const transition = document.startViewTransition(() => {
          root.classList.toggle('dark', nextDark);
        });
        await transition.ready;
        root.animate(
          {
            clipPath: [`circle(0px at ${x}px ${y}px)`, `circle(${radius}px at ${x}px ${y}px)`],
          },
          {
            duration: 1000,
            easing: 'cubic-bezier(0.65, 0, 1, 1)',
            fill: 'both',
            pseudoElement: '::view-transition-new(root)',
          }
        );
        await transition.finished.finally(() => {
          root.classList.remove('theme-reveal');
        });
      };
      const setupThemeToggle = () => {
        if (window.__themeToggleSetupDone) return;
        window.__themeToggleSetupDone = true;
        let animating = false;

        document.addEventListener('click', async (event) => {
          const button = event.target?.closest?.('#theme-toggle');
          if (!button || animating) return;
          animating = true;
          button.setAttribute('disabled', 'true');
          const nextDark = !root.classList.contains('dark');
          await animateThemeReveal(button, nextDark);
          localStorage.setItem('theme', nextDark ? 'dark' : 'light');
          setThemeLabel();
          button.removeAttribute('disabled');
          animating = false;
        });

        // Keep theme stable across client-side route transitions.
        document.addEventListener('astro:before-swap', (event) => {
          if (event.newDocument) syncThemeToIncomingDocument(event.newDocument);
        });
        document.addEventListener('astro:page-load', () => {
          applyTheme(getResolvedDark());
          setThemeLabel();
        });
      };
      const setupStickyHeader = () => {
        if (window.__stickyHeaderSetupDone) return;
        window.__stickyHeaderSetupDone = true;

        let header = document.getElementById('site-header');
        if (!header) return;

        let lastY = window.scrollY;
        const threshold = 8;

        const updateHeaderVisibility = () => {
          if (!header) return;
          const currentY = window.scrollY;
          const delta = currentY - lastY;

          if (currentY <= 0 || delta < -threshold) {
            header.classList.remove('site-header--hidden');
          } else if (delta > threshold) {
            header.classList.add('site-header--hidden');
          }

          lastY = currentY;
        };

        window.addEventListener('scroll', updateHeaderVisibility, { passive: true });
        document.addEventListener('astro:page-load', () => {
          header = document.getElementById('site-header');
          if (!header) return;
          updateHeaderVisibility();
          lastY = window.scrollY;
        });
      };
      const setupScrollRestoration = () => {
        if (window.__scrollRestoreSetupDone) return;
        window.__scrollRestoreSetupDone = true;

        const STORAGE_PREFIX = 'scroll-pos:';
        const buildKey = () =>
          `${STORAGE_PREFIX}${window.location.pathname}${window.location.search}${window.location.hash}`;
        const saveScrollPosition = () => {
          try {
            sessionStorage.setItem(buildKey(), String(window.scrollY));
          } catch {
            // Ignore storage access errors (private mode/storage limits).
          }
        };
        const restoreScrollOnReload = () => {
          const nav = performance.getEntriesByType('navigation')[0];
          const isReload = nav?.type === 'reload' || performance.navigation?.type === 1;
          if (!isReload) return;
          if (window.location.hash) return;

          let saved = '';
          try {
            saved = sessionStorage.getItem(buildKey()) ?? '';
          } catch {
            return;
          }
          if (!saved) return;

          const targetY = Number(saved);
          if (!Number.isFinite(targetY)) return;

          let attempts = 0;
          const maxAttempts = 8;
          const tryRestore = () => {
            window.scrollTo(0, targetY);
            attempts += 1;
            if (attempts < maxAttempts && Math.abs(window.scrollY - targetY) > 1) {
              requestAnimationFrame(tryRestore);
            }
          };
          requestAnimationFrame(tryRestore);
        };

        window.addEventListener('pagehide', saveScrollPosition);
        window.addEventListener('beforeunload', saveScrollPosition);
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') saveScrollPosition();
        });
        document.addEventListener('astro:page-load', restoreScrollOnReload);
        restoreScrollOnReload();
      };
      setupThemeToggle();
      setupStickyHeader();
      setupScrollRestoration();
      applyTheme(getResolvedDark());
      setThemeLabel();
      document.addEventListener('astro:page-load', enablePageTransitionsAfterFirstLoad, { once: true });
      enablePageTransitionsAfterFirstLoad();
    </script>
  </body>
</html>
